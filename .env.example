# closeyourit-ruby — variabili del progetto MONITORATO (non della gemma)
# In sviluppo locale usare `doppler run` invece di un .env reale (vedi rules/doppler.md).

# URL base del server CloseYourIt (la gemma appende /api/v1/projects/:id/{events,metrics})
CLOSEYOURIT_ENDPOINT_URL=https://closeyour.it

# Bearer secret del Projects::Token (mostrato UNA volta alla creazione, lato CloseYourIt)
CLOSEYOURIT_TOKEN=

# UUID del progetto su CloseYourIt (compare nel path di ingest)
CLOSEYOURIT_PROJECT_ID=

# Opzionale: versione/release riportata negli eventi errore
# CLOSEYOURIT_RELEASE=v1.2.3

# Opzionale: forza l'ambiente riportato negli eventi (default: Rails.env / RACK_ENV)
# CLOSEYOURIT_ENVIRONMENT=production
